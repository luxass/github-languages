{
  "name": "@luxass/github-languages",
  "version": "2.1.7",
  "description": "GitHub's supported languages",
  "keywords": [
    "github",
    "github languages",
    "languages",
    "linguist"
  ],
  "homepage": "https://github.com/luxass/github-languages",
  "bugs": {
    "url": "https://github.com/luxass/github-languages/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lucas Nørgård",
    "email": "lucasnrgaard@gmail.com",
    "url": "https://luxass.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxass/github-languages.git"
  },
  "files": [
    "dist",
    "languages.d.ts",
    "languages.json"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./languages": {
      "import": "./dist/languages.mjs",
      "require": "./dist/languages.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "languages:download": "node --env-file=.env ./scripts/download.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "publint": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "valibot": "catalog:dev",
    "yaml": "catalog:dev"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
